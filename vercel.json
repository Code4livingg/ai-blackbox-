{
  "buildCommand": "npm --prefix dashboard install && npm --prefix dashboard run build",
  "outputDirectory": "dashboard/dist",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
